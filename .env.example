# ----------------------------------------------------------------------
# Configuración de ejemplo. Copia este archivo a .env y rellena los valores.
# NUNCA pongas valores reales aquí ni subas .env al repositorio.
# ----------------------------------------------------------------------

# --- LLM (Ollama local) ---
LLM_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# --- Embeddings (Sentence Transformers) ---
# Modelo multilingüe recomendado por el contenido en español
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# --- Vector store (ChromaDB local) ---
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=immigration_docs

# --- Retrieval ---
RETRIEVAL_TOP_K=4
RETRIEVAL_MIN_SCORE=0.70

# --- Chunking ---
CHUNK_SIZE=500
CHUNK_OVERLAP=80

# --- Ingesta / seguridad de archivos ---
MAX_FILE_SIZE_MB=25
MAX_PAGES=300
MAX_INPUT_CHARS=2000

# --- Observabilidad ---
OBSERVABILITY_SINK=jsonl
OBSERVABILITY_PATH=./logs/interactions.jsonl
REDACT_PII=true

# --- App ---
APP_TITLE=Asesor Migratorio RAG
LOG_LEVEL=INFO
